<script>
    let selectedAmount = 50;
    let photoUploaded = false;
    let photoFile = null;
    let currentPaymentMethod = 'qr';
    let bankAccountNumber = '093-8-29649-9';
    let bankAccountName = 'วาที';

    // ===== PAYMENT METHOD SELECTION =====
    function selectPaymentMethod(method) {
        currentPaymentMethod = method;
        
        // Update button styles
        document.querySelectorAll('.payment-method-btn').forEach(btn => {
            btn.classList.remove('active', 'bg-gradient-to-br', 'from-pink-500/20', 'to-purple-500/20', 'border-pink-500');
            btn.classList.add('bg-zinc-900', 'border-zinc-700');
        });
        
        if (method === 'qr') {
            document.querySelector('[onclick="selectPaymentMethod(\'qr\')"]').classList.add('active', 'bg-gradient-to-br', 'from-pink-500/20', 'to-purple-500/20', 'border-pink-500');
            document.querySelector('[onclick="selectPaymentMethod(\'qr\')"]').classList.remove('bg-zinc-900', 'border-zinc-700');
            document.getElementById('qr-payment-section').style.display = 'block';
            document.getElementById('bank-payment-section').style.display = 'none';
            document.getElementById('payment-method-display').textContent = 'QR Code (PromptPay)';
            generateQRCode();
        } else {
            document.querySelector('[onclick="selectPaymentMethod(\'bank\')"]').classList.add('active', 'bg-gradient-to-br', 'from-blue-500/20', 'to-cyan-500/20', 'border-blue-500');
            document.querySelector('[onclick="selectPaymentMethod(\'bank\')"]').classList.remove('bg-zinc-900', 'border-zinc-700');
            document.getElementById('qr-payment-section').style.display = 'none';
            document.getElementById('bank-payment-section').style.display = 'block';
            document.getElementById('payment-method-display').textContent = 'โอนธนาคารโดยตรง';
        }
    }

    // ===== QR CODE GENERATION =====
    function generateQRCode() {
        const qrcodeContainer = document.getElementById('qrcode-container');
        qrcodeContainer.innerHTML = ''; // Clear previous QR
        
        // PromptPay QR Code format (simplified)
        // In production, use proper QR library with PromptPay API
        const promptPayCode = `00020126360014th.co.bbl.promptpay0015${bankAccountNumber}54040013303651065802TH6304D09E`;
        
        new QRCode(qrcodeContainer, {
            text: promptPayCode,
            width: 250,
            height: 250,
            colorDark: "#000000",
            colorLight: "#ffffff",
            correctLevel: QRCode.CorrectLevel.H
        });
    }

    // ===== OPEN BANK APP =====
    function openPromptPayApp() {
        const sender = document.getElementById('sender').value.trim();
        const message = document.getElementById('message').value.trim();

        if (!sender || !message) {
            showValidationMessage('กรุณากรอกชื่อและข้อความก่อน', 'error');
            return;
        }

        if (!photoUploaded) {
            showValidationMessage('กรุณาอัพโหลดรูปภาพก่อน', 'error');
            return;
        }

        // PromptPay Deep Link (สำหรับธนาคารไทย)
        const bankAppUrl = `promptpay://pay/${bankAccountNumber}/${selectedAmount}`;
        
        // Fallback to app store if PromptPay not available
        setTimeout(() => {
            window.location.href = bankAppUrl;
        }, 500);

        // Show success message
        submitTip(sender, message);
    }

    // ===== LINEUP UPLOAD =====
    function handleLineupUpload(event) {
        const file = event.target.files[0];
        if (file) {
            if (file.size > 10 * 1024 * 1024) {
                alert('ไฟล์ขนาดใหญ่เกินไป (สูงสุด 10MB)');
                return;
            }

            if (!file.type.startsWith('image/')) {
                alert('กรุณาเลือกไฟล์รูปภาพเท่านั้น');
                return;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('lineup-img').src = e.target.result;
            };
            reader.readAsDataURL(file);
        }
    }

    // ===== TIP SELECTION =====
    function selectTip(el) {
        document.querySelectorAll('.tip-btn').forEach(btn => {
            btn.classList.remove('active', 'border-pink-500', 'text-pink-400');
            btn.classList.add('border-zinc-700', 'text-white');
        });
        el.classList.add('active', 'border-pink-500', 'text-pink-400');
        selectedAmount = parseInt(el.dataset.amount);
        updateAmountDisplay();
    }

    function useCustomAmount() {
        const custom = document.getElementById('custom-amount').value;
        if (custom && parseInt(custom) > 0) {
            if (parseInt(custom) < 10) {
                alert('จำนวนต่ำสุด 10 บาท');
                return;
            }
            if (parseInt(custom) > 100000) {
                alert('จำนวนสูงสุด 100,000 บาท');
                return;
            }
            selectedAmount = parseInt(custom);
            
            document.querySelectorAll('.tip-btn').forEach(btn => {
                btn.classList.remove('active', 'border-pink-500', 'text-pink-400');
                btn.classList.add('border-zinc-700', 'text-white');
            });
            
            updateAmountDisplay();
        } else {
            alert('กรุณาใส่จำนวนที่ถูกต้อง');
        }
    }

    function updateAmountDisplay() {
        document.getElementById('amount-display').textContent = selectedAmount;
        document.getElementById('qr-amount').textContent = selectedAmount;
        document.getElementById('bank-amount').textContent = selectedAmount;
        document.getElementById('summary-amount').textContent = selectedAmount;
        
        // Generate QR if on QR tab
        if (currentPaymentMethod === 'qr') {
            generateQRCode();
        }
    }

    // ===== PHOTO UPLOAD =====
    function handlePhotoUpload(event) {
        const file = event.target.files[0];
        if (file) {
            if (file.size > 10 * 1024 * 1024) {
                alert('ไฟล์ขนาดใหญ่เกินไป (สูงสุด 10MB)');
                return;
            }

            if (!file.type.startsWith('image/')) {
                alert('กรุณาเลือกไฟล์รูปภาพเท่านั้น');
                return;
            }

            photoFile = file;
            photoUploaded = true;

            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('preview-img').src = e.target.result;
                document.getElementById('photo-empty').style.display = 'none';
                document.getElementById('photo-preview').style.display = 'block';
                document.getElementById('photo-status').innerHTML = '<i class="fas fa-check text-green-500"></i> อัพโหลดแล้ว';
            };
            reader.readAsDataURL(file);
        }
    }

    function clearPhoto(event) {
        event.stopPropagation();
        photoUploaded = false;
        photoFile = null;
        document.getElementById('photo-input').value = '';
        document.getElementById('photo-preview').style.display = 'none';
        document.getElementById('photo-empty').style.display = 'block';
        document.getElementById('photo-status').innerHTML = '<i class="fas fa-times text-red-500"></i> ยังไม่อัพโหลด';
    }

    // ===== VALIDATION =====
    function validateAndSendTip() {
        const sender = document.getElementById('sender').value.trim();
        const message = document.getElementById('message').value.trim();

        if (!sender) {
            showValidationMessage('กรุณาใส่ชื่อผู้ส่ง', 'error');
            return;
        }

        if (!message) {
            showValidationMessage('กรุณาเขียนข้อความ', 'error');
            return;
        }

        if (!photoUploaded) {
            showValidationMessage('กรุณาอัพโหลดรูปภาพ', 'error');
            return;
        }

        // All validations passed - proceed with payment
        if (currentPaymentMethod === 'qr') {
            openPromptPayApp();
        } else {
            // For bank transfer, just show success and info
            submitTip(sender, message);
        }
    }

    function showValidationMessage(message, type) {
        const msgDiv = document.getElementById('validation-message');
        const bgColor = type === 'error' ? 'bg-red-500/20' : 'bg-green-500/20';
        const textColor = type === 'error' ? 'text-red-300' : 'text-green-300';
        const borderColor = type === 'error' ? 'border-red-500/30' : 'border-green-500/30';
        const icon = type === 'error' ? 'fa-exclamation-circle' : 'fa-check-circle';
        
        msgDiv.innerHTML = `<div class="${bgColor} border ${borderColor} rounded-2xl p-4 ${textColor}"><i class="fas ${icon}"></i> ${message}</div>`;
        
        setTimeout(() => {
            msgDiv.innerHTML = '';
        }, 5000);
    }

    function submitTip(sender, message) {
        // Update summary
        document.getElementById('summary-sender').textContent = sender;
        document.getElementById('summary-message').textContent = message.substring(0, 50) + (message.length > 50 ? '...' : '');

        const btn = document.getElementById('send-btn');
        const originalHTML = btn.innerHTML;
        
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> กำลังประมวลผล...';

        // Simulate submission
        setTimeout(() => {
            const data = {
                amount: selectedAmount,
                message: message,
                sender: sender,
                paymentMethod: currentPaymentMethod,
                timestamp: new Date().toISOString(),
                photo: photoFile ? photoFile.name : null
            };

            console.log('Tips Data:', data);

            btn.classList.add('success-animation');
            btn.innerHTML = '<i class="fas fa-check-circle"></i> บันทึกแล้ว! รอการโอนเงิน ❤️';
            btn.style.background = 'linear-gradient(to right, #10b981, #34d399)';

            showValidationMessage(`✓ บันทึก Tips จำนวน ${selectedAmount} บาท\n\nจาก: ${sender}\n\n⏳ รอการโอนเงิน...`, 'success');

            setTimeout(() => {
                resetForm();
                btn.disabled = false;
                btn.classList.remove('success-animation');
                btn.innerHTML = originalHTML;
                btn.style.background = '';
            }, 3000);
        }, 1500);
    }

    function resetForm() {
        document.getElementById('message').value = '';
        document.getElementById('sender').value = '';
        document.getElementById('custom-amount').value = '';
        
        selectedAmount = 50;
        updateAmountDisplay();
        
        document.querySelectorAll('.tip-btn').forEach((btn, idx) => {
            if (idx === 0) {
                btn.classList.add('active', 'border-pink-500', 'text-pink-400');
                btn.classList.remove('border-zinc-700', 'text-white');
            } else {
                btn.classList.remove('active', 'border-pink-500', 'text-pink-400');
                btn.classList.add('border-zinc-700', 'text-white');
            }
        });
        
        clearPhoto({stopPropagation: () => {}});
    }

    // ===== KEYBOARD SUPPORT =====
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && 
            document.activeElement.tagName !== 'TEXTAREA' &&
            document.activeElement.id !== 'custom-amount') {
            validateAndSendTip();
        }
    });

    // Initialize
    updateAmountDisplay();
    selectPaymentMethod('qr');
</script>
```

</body>
</html>