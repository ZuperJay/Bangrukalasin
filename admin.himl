```
    :root {
        --primary: #ff0088;
    }
    
    body {
        font-family: 'Prompt', system-ui, sans-serif;
    }

    /* 3D Logo Effect */
    .logo-3d {
        font-family: 'Orbitron', 'Courier New', monospace;
        font-weight: 900;
        letter-spacing: 3px;
        text-shadow: 
            0px 0px 20px #ff0088,
            0px 0px 40px #ff0088,
            0px 0px 60px #ff0088,
            3px 3px 0px rgba(255, 0, 136, 0.5),
            6px 6px 0px rgba(255, 0, 136, 0.3),
            9px 9px 0px rgba(0, 0, 0, 0.5);
        transform: perspective(1000px) rotateY(0deg);
        animation: glow-pulse 2s ease-in-out infinite;
    }

    /* LED Running Animation */
    @keyframes led-run {
        0% {
            background-position: 0% center;
        }
        100% {
            background-position: 200% center;
        }
    }

    .led-text {
        background: linear-gradient(90deg, #ff0088, #ff6bb6, #ff0088, #ff6bb6);
        background-size: 200% 100%;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: led-run 3s linear infinite;
        font-family: 'Orbitron', monospace;
        font-weight: 700;
        font-size: 1.2em;
        letter-spacing: 2px;
    }

    /* Glow Pulse */
    @keyframes glow-pulse {
        0%, 100% {
            text-shadow: 
                0px 0px 20px #ff0088,
                0px 0px 40px #ff0088,
                0px 0px 60px #ff0088,
                3px 3px 0px rgba(255, 0, 136, 0.5);
        }
        50% {
            text-shadow: 
                0px 0px 30px #ff0088,
                0px 0px 50px #ff0088,
                0px 0px 80px #ff0088,
                3px 3px 0px rgba(255, 0, 136, 0.8);
        }
    }

    .logo-glow {
        text-shadow: 0 0 20px #ff0088,
                    0 0 40px #ff0088;
    }
    
    .tip-btn {
        transition: all 0.2s ease;
    }
    
    .tip-btn.active {
        background-color: #ff0088 !important;
        color: white !important;
        border-color: #ff0088;
        transform: scale(1.05);
    }
    
    .neon-text {
        text-shadow: 0 0 10px #ff0088,
                    0 0 20px #ff0088;
    }

    .step-container {
        background: linear-gradient(135deg, rgba(255,0,136,0.05) 0%, rgba(168,85,247,0.05) 100%);
        border: 1px solid rgba(255,0,136,0.2);
        border-radius: 1.5rem;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .preview-image {
        max-width: 300px;
        max-height: 300px;
        border-radius: 1rem;
        object-fit: cover;
    }

    .payment-info {
        background: linear-gradient(135deg, #ff0088 0%, #a855f7 100%);
        padding: 1.5rem;
        border-radius: 1.5rem;
        color: white;
        margin: 1.5rem 0;
    }

    .payment-details {
        background: rgba(0,0,0,0.3);
        padding: 1rem;
        border-radius: 1rem;
        margin-top: 1rem;
        font-family: monospace;
        font-size: 1.1rem;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1rem;
        border-radius: 2rem;
        font-weight: 500;
        margin-top: 1rem;
    }

    .status-pending {
        background: #fbbf24;
        color: #000;
    }

    .status-verified {
        background: #10b981;
        color: white;
    }

    .status-error {
        background: #ef4444;
        color: white;
    }

    .success-animation {
        animation: successPulse 0.6s ease-out;
    }

    @keyframes successPulse {
        0% {
            transform: scale(0.95);
            opacity: 0.8;
        }
        50% {
            transform: scale(1.05);
        }
        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    /* Modern Gradient Button */
    .btn-modern {
        background: linear-gradient(135deg, #ff0088 0%, #a855f7 50%, #0891b2 100%);
        background-size: 200% 200%;
        animation: gradient-shift 3s ease infinite;
    }

    @keyframes gradient-shift {
        0%, 100% {
            background-position: 0% 50%;
        }
        50% {
            background-position: 100% 50%;
        }
    }
</style>
