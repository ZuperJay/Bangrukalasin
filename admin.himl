<div class="max-w-2xl mx-auto px-4 py-8">
    <!-- Logo -->
    <div class="flex justify-center mb-8">
        <div class="bg-black p-6 rounded-2xl border border-pink-500/50 shadow-2xl shadow-pink-500/30">
            <div class="text-center">
                <h1 class="text-6xl font-black tracking-widest logo-3d text-pink-400 mb-2">
                    BANGRU
                </h1>
                <div class="led-text text-2xl mb-3">⚡ KALASIN ⚡</div>
                <p class="text-lg text-pink-400 font-semibold">CLUB & BAR</p>
                <p class="text-sm text-pink-300 mt-1">✨ 2025 ✨</p>
            </div>
        </div>
    </div>

    <div class="text-center mb-8">
        <p class="text-pink-400 text-lg font-medium">CLUB & BAR • KALASIN • 18+ ONLY</p>
        <p class="text-pink-300 mt-2 text-sm">SEND TIPS TO DJ & STAFF</p>
    </div>

    <!-- Firebase Live -->
    <div class="bg-gradient-to-r from-pink-500/10 to-purple-500/10 border border-pink-500/30 rounded-2xl p-4 mb-8 text-center">
        <div class="inline-flex items-center gap-2 bg-green-500/10 text-green-400 px-4 py-1 rounded-full text-sm font-medium">
            <div class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></div>
            LIVE SYSTEM
        </div>
    </div>

    <!-- Step 1: ถ่ายรูป LED -->
    <div class="step-container">
        <div class="flex items-center gap-3 mb-4">
            <div class="bg-pink-500 text-black font-bold w-8 h-8 rounded-full flex items-center justify-center">01</div>
            <h2 class="text-xl font-semibold">ถ่ายรูป LED (ส่งรูปให้เรา)</h2>
        </div>
        
        <div class="border-2 border-dashed border-pink-500/50 rounded-3xl p-10 text-center hover:border-pink-500 transition-colors cursor-pointer" onclick="document.getElementById('photo-input').click()">
            <div id="photo-preview" style="display: none;" class="mb-4">
                <img id="preview-img" src="" alt="Preview" class="preview-image mx-auto">
                <button onclick="clearPhoto(event)" class="mt-3 bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg text-sm">
                    <i class="fas fa-trash"></i> ลบรูป
                </button>
            </div>
            
            <div id="photo-empty">
                <div class="mx-auto w-20 h-20 bg-gray-800 rounded-2xl flex items-center justify-center mb-4">
                    <i class="fas fa-camera text-4xl text-pink-400"></i>
                </div>
                <p class="font-medium">คลิกเพื่ออัพโหลดรูปถ่ายกับสนุก LED</p>
                <p class="text-sm text-pink-300 mt-1">รูปสด ๆ จากปาร์ตี้ของเรา!</p>
            </div>
        </div>

        <input type="file" id="photo-input" accept="image/*" style="display: none;" onchange="handlePhotoUpload(event)">
        <small class="text-zinc-500 block mt-3">ขนาดไฟล์: ไม่เกิน 10MB | รูปแบบ: JPG, PNG</small>
    </div>

    <!-- Step 2: เลือกจำนวน Tips -->
    <div class="step-container">
        <div class="flex items-center gap-3 mb-6">
            <div class="bg-pink-500 text-black font-bold w-8 h-8 rounded-full flex items-center justify-center">02</div>
            <h2 class="text-xl font-semibold">เลือกจำนวน Tips</h2>
        </div>

        <!-- Tip Amounts -->
        <div class="grid grid-cols-3 gap-3 mb-6" id="tip-grid">
            <button onclick="selectTip(this)" data-amount="50" class="tip-btn active bg-zinc-900 hover:bg-zinc-800 border-2 border-pink-500 text-pink-400 font-bold text-2xl py-6 rounded-3xl">50</button>
            <button onclick="selectTip(this)" data-amount="100" class="tip-btn bg-zinc-900 hover:bg-zinc-800 border border-zinc-700 text-white font-bold text-2xl py-6 rounded-3xl">100</button>
            <button onclick="selectTip(this)" data-amount="200" class="tip-btn bg-zinc-900 hover:bg-zinc-800 border border-zinc-700 text-white font-bold text-2xl py-6 rounded-3xl">200</button>
            <button onclick="selectTip(this)" data-amount="300" class="tip-btn bg-zinc-900 hover:bg-zinc-800 border border-zinc-700 text-white font-bold text-2xl py-6 rounded-3xl">300</button>
            <button onclick="selectTip(this)" data-amount="500" class="tip-btn bg-zinc-900 hover:bg-zinc-800 border border-zinc-700 text-white font-bold text-2xl py-6 rounded-3xl">500</button>
            <button onclick="selectTip(this)" data-amount="1000" class="tip-btn bg-zinc-900 hover:bg-zinc-800 border border-zinc-700 text-white font-bold text-2xl py-6 rounded-3xl">1K</button>
        </div>

        <!-- Custom Amount -->
        <div class="mb-6">
            <div class="flex items-center gap-2 text-pink-400 mb-3">
                <i class="fas fa-edit"></i>
                <span class="font-medium">จำนวนอื่นๆ</span>
            </div>
            <div class="flex gap-3">
                <input 
                    type="number" 
                    id="custom-amount"
                    class="flex-1 bg-zinc-900 border border-pink-500/30 rounded-2xl px-6 py-5 text-2xl focus:outline-none focus:border-pink-500 text-center"
                    placeholder="กรอกจำนวน"
                    min="10">
                <button onclick="useCustomAmount()" 
                        class="bg-pink-500 hover:bg-pink-600 transition-colors text-black font-bold px-8 rounded-2xl">
                    ใช้
                </button>
            </div>
        </div>

        <div class="bg-zinc-900 p-4 rounded-2xl text-center">
            <p class="text-zinc-400 text-sm">จำนวนเงินที่เลือก</p>
            <p class="text-4xl font-bold text-pink-400 mt-2"><span id="amount-display">50</span> <span class="text-xl">บาท</span></p>
        </div>
    </div>

    <!-- Step 3: ข้อความ -->
    <div class="step-container">
        <div class="flex items-center gap-3 mb-4">
            <div class="bg-pink-500 text-black font-bold w-8 h-8 rounded-full flex items-center justify-center">03</div>
            <h2 class="text-xl font-semibold">ข้อความและชื่อผู้ส่ง</h2>
        </div>
        
        <label class="block text-sm text-pink-300 mb-2">ข้อความถึง DJ / พนักงาน</label>
        <textarea 
            id="message"
            rows="3"
            class="w-full bg-zinc-900 border border-pink-500/30 rounded-2xl p-5 focus:outline-none focus:border-pink-500 resize-none text-white placeholder-zinc-500"
            placeholder="เช่น: ให้ DJ ขอเพลง, ซัพพอร์ต, ฯลฯ"></textarea>
        
        <div class="mt-4">
            <label class="block text-sm text-pink-300 mb-2">ชื่อผู้ส่ง</label>
            <input 
                type="text"
                id="sender"
                class="w-full bg-zinc-900 border border-pink-500/30 rounded-2xl p-5 focus:outline-none focus:border-pink-500"
                placeholder="ชื่อเล่น / ชื่อจริง">
        </div>
    </div>

    <!-- Step 4: QR Payment / PromptPay -->
    <div class="step-container">
        <div class="flex items-center gap-3 mb-4">
            <div class="bg-pink-500 text-black font-bold w-8 h-8 rounded-full flex items-center justify-center">04</div>
            <h2 class="text-xl font-semibold">เลือกวิธีชำระเงิน</h2>
        </div>

        <div class="grid grid-cols-2 gap-4 mb-6">
            <!-- QR Payment Option -->
            <button onclick="selectPaymentMethod('qr')" class="payment-method-btn active bg-gradient-to-br from-pink-500/20 to-purple-500/20 border-2 border-pink-500 rounded-2xl p-6 hover:from-pink-500/30 hover:to-purple-500/30 transition-all">
                <div class="text-4xl mb-3">📱</div>
                <p class="font-bold">QR Code</p>
                <p class="text-xs text-pink-300 mt-1">PromptPay / ธนาคาร</p>
            </button>

            <!-- Bank Transfer Option -->
            <button onclick="selectPaymentMethod('bank')" class="payment-method-btn bg-zinc-900 border-2 border-zinc-700 rounded-2xl p-6 hover:border-pink-500/50 transition-all">
                <div class="text-4xl mb-3">🏦</div>
                <p class="font-bold">โอนธนาคาร</p>
                <p class="text-xs text-zinc-400 mt-1">เลขบัญชี</p>
            </button>
        </div>

        <!-- QR Payment Section -->
        <div id="qr-payment-section" class="bg-gradient-to-r from-pink-500/10 to-purple-500/10 border border-pink-500/30 rounded-2xl p-6 mb-6">
            <h3 class="text-lg font-bold mb-4 text-center">
                <i class="fas fa-qrcode"></i> QR Code Payment
            </h3>
            
            <div class="text-center mb-6">
                <p class="text-sm text-pink-300 mb-4">กำหนดจำนวนเงินแล้วสแกน QR Code</p>
                <div class="bg-white p-4 rounded-xl mx-auto" style="width: fit-content;">
                    <div id="qrcode-container" style="width: 250px; height: 250px;"></div>
                </div>
            </div>

            <div class="bg-zinc-900 p-4 rounded-2xl text-center mb-4">
                <p class="text-sm text-zinc-400">จำนวนที่ต้องชำระ</p>
                <p class="text-4xl font-bold text-pink-400 mt-2"><span id="qr-amount">50</span> บาท</p>
            </div>

            <button onclick="openPromptPayApp()" class="w-full bg-gradient-to-r from-pink-500 to-purple-600 hover:from-pink-600 hover:to-purple-700 transition-all py-5 rounded-2xl text-xl font-bold flex items-center justify-center gap-3 shadow-xl shadow-pink-500/50">
                <i class="fas fa-mobile-alt"></i>
                เปิดแอปธนาคาร
            </button>

            <p class="text-xs text-zinc-500 text-center mt-4">
                <i class="fas fa-check-circle text-green-500"></i> รองรับ PromptPay / ธนาคารทั้งหมด
            </p>
        </div>

        <!-- Bank Transfer Section -->
        <div id="bank-payment-section" style="display: none;" class="bg-gradient-to-r from-blue-500/10 to-cyan-500/10 border border-blue-500/30 rounded-2xl p-6">
            <h3 class="text-lg font-bold mb-4 text-center">
                <i class="fas fa-university"></i> Bank Transfer
            </h3>
            
            <div class="bg-zinc-900 p-5 rounded-2xl space-y-4 mb-6">
                <div>
                    <p class="text-xs text-zinc-400 mb-1">ชื่อบัญชี</p>
                    <p class="text-lg font-bold">วาที</p>
                </div>
                <div>
                    <p class="text-xs text-zinc-400 mb-1">เลขบัญชี</p>
                    <p class="text-xl font-bold tracking-widest font-mono">093-8-29649-9</p>
                </div>
                <div>
                    <p class="text-xs text-zinc-400 mb-1">ธนาคาร</p>
                    <p class="text-lg font-bold">กสิกรไทย (Kasikornbank)</p>
                </div>
            </div>

            <p class="text-sm text-blue-300 bg-blue-500/20 p-3 rounded-lg">
                <i class="fas fa-info-circle"></i> 
                โปรดโอนเงินจำนวน <strong id="bank-amount">50</strong> บาท ตามจำนวนที่เลือก
            </p>
        </div>
    </div>

    <!-- Step 5: สรุป & ส่ง Tips -->
    <div class="step-container bg-gradient-to-r from-green-500/10 via-emerald-500/10 to-green-500/10">
        <div class="flex items-center gap-3 mb-4">
            <div class="bg-green-500 text-black font-bold w-8 h-8 rounded-full flex items-center justify-center">05</div>
            <h2 class="text-xl font-semibold">ยืนยันและส่ง Tips</h2>
        </div>

        <div class="bg-green-500/20 border border-green-500/30 rounded-2xl p-4 mb-6">
            <p class="text-sm text-green-300 leading-relaxed">
                <i class="fas fa-check-circle"></i> 
                กรุณาตรวจสอบข้อมูลทั้งหมด จากนั้นคลิก "ส่ง Tips" 
                <br><strong>ระบบจะเด้งไปแอปธนาคารโดยอัตโนมัติ</strong>
            </p>
        </div>

        <div class="space-y-3 mb-6 text-sm">
            <div class="flex justify-between pb-2 border-b border-zinc-700">
                <span class="text-zinc-400">จำนวนเงิน:</span>
                <span class="font-bold text-pink-400"><span id="summary-amount">50</span> บาท</span>
            </div>
            <div class="flex justify-between pb-2 border-b border-zinc-700">
                <span class="text-zinc-400">ชื่อผู้ส่ง:</span>
                <span id="summary-sender" class="text-white">-</span>
            </div>
            <div class="flex justify-between pb-2 border-b border-zinc-700">
                <span class="text-zinc-400">ข้อความ:</span>
                <span id="summary-message" class="text-white text-right max-w-xs">-</span>
            </div>
            <div class="flex justify-between pb-2 border-b border-zinc-700">
                <span class="text-zinc-400">สถานะรูปภาพ:</span>
                <span id="photo-status" class="text-white"><i class="fas fa-times text-red-500"></i> รอการอัพโหลด</span>
            </div>
            <div class="flex justify-between">
                <span class="text-zinc-400">วิธีชำระเงิน:</span>
                <span id="payment-method-display" class="font-bold text-pink-400">QR Code</span>
            </div>
        </div>

        <!-- Send Button -->
        <button onclick="validateAndSendTip()" 
                class="w-full btn-modern hover:shadow-2xl hover:shadow-pink-500/50 transition-all py-7 rounded-3xl text-2xl font-bold flex items-center justify-center gap-3 shadow-xl text-white disabled:opacity-50 disabled:cursor-not-allowed" id="send-btn">
            <i class="fas fa-paper-plane"></i>
            ส่ง Tips & เปิดแอปธนาคาร
        </button>

        <div id="validation-message" class="mt-4"></div>
    </div>

</div>

<!-- Footer -->
<footer class="text-center text-xs text-zinc-500 py-8 border-t border-zinc-800 mt-12">
    <p>© 2025 BANG RU KALASIN CLUB & BAR</p>
    <p class="mt-2">สำหรับสอบถาม: Line @bangrukal | Tel: 064-265-3497</p>
